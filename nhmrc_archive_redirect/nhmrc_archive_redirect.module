<?php

/**
 * @file
 * Hook implementations for the NHMRC archive redirect module.
 */

use Drupal\Core\Cache\Cache;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;

/**
 * Invalidate cached redirects when a node transitions to published.
 *
 * When a node is re-published after being unpublished, any cached redirect
 * responses (in Internal Page Cache or Dynamic Page Cache) tagged with this
 * node's cache tag are invalidated so visitors see the live page immediately.
 */
function nhmrc_archive_redirect_entity_update(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface) {
    return;
  }

  $logger = \Drupal::logger('nhmrc_archive_redirect');

  $was_published = isset($entity->original) && $entity->original->isPublished();
  $is_published = $entity->isPublished();

  $logger->debug(
    'hook_entity_update: node @nid, was_published: @was, is_published: @is.',
    [
      '@nid' => $entity->id(),
      '@was' => $was_published ? 'yes' : 'no',
      '@is'  => $is_published ? 'yes' : 'no',
    ]
  );

  // Detect unpublished → published transition.
  if (!$is_published || !isset($entity->original) || $was_published) {
    return;
  }

  $logger->notice(
    'Node @nid transitioned from unpublished to published. Invalidating caches.',
    ['@nid' => $entity->id()]
  );

  // Invalidate the node's cache tag (also done by core, but explicit for clarity).
  Cache::invalidateTags(['node:' . $entity->id()]);

  // Invalidate stored-redirect cache tags for both the alias and raw node path.
  $tags_to_invalidate = ['nhmrc_archive_redirect:source:node/' . $entity->id()];

  $alias = \Drupal::service('path_alias.manager')
    ->getAliasByPath('/node/' . $entity->id());
  if ($alias && $alias !== '/node/' . $entity->id()) {
    $source = ltrim($alias, '/');
    $tags_to_invalidate[] = 'nhmrc_archive_redirect:source:' . $source;
  }

  Cache::invalidateTags($tags_to_invalidate);

  $logger->debug(
    'Invalidated cache tags: @tags. Alias resolved to: @alias.',
    [
      '@tags'  => implode(', ', $tags_to_invalidate),
      '@alias' => $alias ?: '(none)',
    ]
  );

  // Remove any stored redirect records for this node's paths so the
  // DeletedPageRedirectSubscriber does not serve stale redirects.
  $database = \Drupal::database();
  $sources_to_delete = ['node/' . $entity->id()];
  if ($alias && $alias !== '/node/' . $entity->id()) {
    $sources_to_delete[] = ltrim($alias, '/');
  }

  try {
    $deleted = $database->delete('nhmrc_archive_redirect_records')
      ->condition('source', $sources_to_delete, 'IN')
      ->execute();
    if ($deleted > 0) {
      $logger->notice(
        'Removed @count stored redirect record(s) for re-published node @nid (paths: @paths).',
        [
          '@count' => $deleted,
          '@nid'   => $entity->id(),
          '@paths' => implode(', ', $sources_to_delete),
        ]
      );
    }
  }
  catch (\Exception $e) {
    // Table may not exist yet.
  }
}

/**
 * Store the node alias before deletion so it is available in hook_entity_delete.
 */
function nhmrc_archive_redirect_entity_predelete(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface) {
    return;
  }

  // Only bother if delete path rules are configured.
  $rules = \Drupal::config('nhmrc_archive_redirect.settings')->get('delete_path_rules') ?? [];
  if (empty($rules)) {
    return;
  }

  $alias = \Drupal::service('path_alias.manager')
    ->getAliasByPath('/node/' . $entity->id());

  $store = &drupal_static(__FUNCTION__, []);
  $store[$entity->uuid()] = $alias;
}

/**
 * On node delete, match alias against path-prefix rules and store a redirect.
 */
function nhmrc_archive_redirect_entity_delete(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface) {
    return;
  }

  $config = \Drupal::config('nhmrc_archive_redirect.settings');
  $rules = $config->get('delete_path_rules') ?? [];
  if (empty($rules)) {
    return;
  }

  $store = &drupal_static('nhmrc_archive_redirect_entity_predelete', []);
  $alias = $store[$entity->uuid()] ?? NULL;

  // Skip if there is no meaningful alias (raw node path).
  if (!$alias || $alias === '/node/' . $entity->id()) {
    return;
  }

  // Find the best matching rule (longest prefix wins).
  $destination = _nhmrc_archive_redirect_match_rule($alias, $rules);
  if ($destination === NULL) {
    return;
  }

  // Resolve <front> to the real front-page path.
  if ($destination === '<front>') {
    $destination = Url::fromRoute('<front>')->toString();
  }

  $source = ltrim($alias, '/');
  $database = \Drupal::database();

  // Avoid duplicates.
  $exists = $database->select('nhmrc_archive_redirect_records', 'r')
    ->fields('r', ['id'])
    ->condition('source', $source)
    ->execute()
    ->fetchField();

  if ($exists) {
    return;
  }

  $status = (int) ($config->get('status_code') ?? 302);

  $database->insert('nhmrc_archive_redirect_records')
    ->fields([
      'source'      => $source,
      'destination' => $destination,
      'status_code' => $status,
      'created'     => \Drupal::time()->getRequestTime(),
    ])
    ->execute();

  if ($config->get('log_redirects')) {
    \Drupal::logger('nhmrc_archive_redirect')->notice(
      'Stored delete redirect: @alias → @dest (@status).',
      [
        '@alias'  => $alias,
        '@dest'   => $destination,
        '@status' => $status,
      ]
    );
  }
}

/**
 * Returns the destination for the best-matching prefix rule, or NULL.
 *
 * Longest-prefix match wins. Prefix comparison is case-sensitive.
 */
function _nhmrc_archive_redirect_match_rule(string $path, array $rules): ?string {
  $best_dest = NULL;
  $best_len  = 0;

  foreach ($rules as $rule) {
    $prefix = $rule['source_prefix'] ?? '';
    if ($prefix === '') {
      continue;
    }
    if (!str_starts_with($prefix, '/')) {
      $prefix = '/' . $prefix;
    }
    if (str_starts_with($path, $prefix) && strlen($prefix) > $best_len) {
      $best_len  = strlen($prefix);
      $best_dest = $rule['destination'] ?? '';
    }
  }

  return ($best_dest !== NULL && $best_dest !== '') ? $best_dest : NULL;
}

modules = ["php-8.2"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PHP_CLI_SERVER_WORKERS=4 php -S 0.0.0.0:5000 -t /home/runner/workspace/drupal/web /home/runner/workspace/drupal/web/router.php"
waitForPort = 5000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "PHP_CLI_SERVER_WORKERS=4 php -S 0.0.0.0:5000 -t /home/runner/workspace/drupal/web /home/runner/workspace/drupal/web/router.php"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
